---
import Icon from "./Icon.astro";
import { Image } from "astro:assets";
import config from "virtual:starlight/user-config";
import wpanchorbayIcon from "../../assets/wpanchorbay-icon.svg";
import { EXTERNAL_LINKS } from '../../lib/links';

const { social } = config;

// Normalize social links to an array of { href, icon, label }
const links = social
	? Array.isArray(social)
		? social
		: Object.entries(social).map(([platform, url]) => ({
				href: typeof url === "string" ? url : (url as any).href,
				icon: platform,
				label: platform.charAt(0).toUpperCase() + platform.slice(1),
			}))
	: [];
---

{
	links.map(({ href, icon, label }) => (
		<a href={href} rel="me" class="sl-flex social-link">
			<span class="sr-only">{label}</span>
			{icon === 'github' ? (
				<svg viewBox="0 0 24 24" aria-hidden="true" width="24" height="24" fill="currentColor" class="github-icon">
					<path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.744.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.605-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.527.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.649.242 2.872.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
				</svg>
			) : (
				<Icon name={icon as any} />
			)}
		</a>
	))
}
<a href={EXTERNAL_LINKS.wpAnchorBay} rel="me" class="sl-flex custom-social-link">
	<span class="sr-only">WPAnchorBay</span>
	<Image src={wpanchorbayIcon} alt="" width={24} height={24} />
</a>

<style>
	a {
		color: var(--sl-color-text-accent);
		padding: 0.5rem;
		margin: -0.5rem;
		align-items: center;
	}
	a:hover {
		opacity: 0.66;
	}
	.github-icon {
		width: 1.35rem; /* Slightly smaller to match visual weight of the PNG icon */
		height: 1.35rem;
		color: #000; /* Black for light mode */
	}
	:root[data-theme='dark'] .github-icon {
		color: #fff; /* White for dark mode */
	}
	.custom-social-link img {
		width: 1.5rem;
		height: 1.5rem;
		object-fit: contain;
	}
</style>
